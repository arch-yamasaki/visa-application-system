{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review.schema.json",
  "title": "AI extraction review output",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "expected_route",
    "missing_documents",
    "missing_items",
    "validation_errors",
    "findings",
    "assessments"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "expected_route": {
      "type": "string",
      "enum": ["ok", "needs_review", "needs_information", "human_required"]
    },
    "missing_documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_item"
      }
    },
    "missing_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_item"
      }
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_item"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "additionalProperties": true,
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "message": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "status", "summary"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "review_item": {
      "type": "object",
      "required": ["path", "reason"],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
