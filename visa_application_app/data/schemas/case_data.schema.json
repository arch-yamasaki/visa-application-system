{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/visa/case_data.schema.json",
  "title": "Visa Application Case Data",
  "description": "在留資格申請AI支援で扱う正規caseデータ。Chrome拡張の画面入力IDには依存させない。",
  "type": "object",
  "required": ["schema_version", "case", "applicant", "application"],
  "properties": {
    "schema_version": { "type": "string" },
    "case": {
      "type": "object",
      "required": ["case_id", "application_type", "target_status", "workflow_state"],
      "properties": {
        "case_id": { "type": "string" },
        "intake_channel": {
          "type": "string",
          "enum": ["direct_applicant", "employer", "recruiting_agency", "cooperative", "professional_referral", "unknown"]
        },
        "source_organization": { "type": "string" },
        "application_type": {
          "type": "string",
          "enum": ["certificate_of_eligibility", "change_status", "renewal", "family", "unknown"]
        },
        "target_status": {
          "type": "string",
          "enum": ["engineer_humanities_international", "highly_skilled_professional", "skilled_labor", "specified_skilled_worker", "entertainer", "spouse", "family_stay", "unknown"]
        },
        "workflow_state": {
          "type": "string",
          "enum": ["draft", "needs_information", "needs_review", "ready_to_fill", "filled", "submitted"]
        },
        "routed_to_human_reason": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "application": {
      "type": "object",
      "properties": {
        "desired_status_label": { "type": "string" },
        "purpose_of_entry": { "type": "string" },
        "planned_entry_date": { "type": "string" },
        "planned_port": { "type": "string" },
        "planned_port_other": { "type": "string" },
        "planned_period_years": { "type": "string" },
        "planned_period_months": { "type": "string" },
        "visa_application_location": { "type": "string" },
        "activity_details": { "type": "string" },
        "activity_details_structured": {
          "type": "object",
          "properties": {
            "department": { "type": "string" },
            "role": { "type": "string" },
            "duties": { "type": "array", "items": { "type": "string" } },
            "simple_labor_risk_terms": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "previous_denial_reason": { "type": "string" },
        "amendment_history": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "applicant": {
      "type": "object",
      "properties": {
        "nationality_region": { "type": "string" },
        "birth_date": { "type": "string" },
        "name_roman": { "type": "string" },
        "name_kanji": { "type": "string" },
        "sex": { "type": "string", "enum": ["male", "female", "other", "unknown"] },
        "birth_place": { "type": "string" },
        "marital_status": { "type": "string", "enum": ["married", "single", "divorced", "widowed", "unknown"] },
        "occupation": { "type": "string" },
        "home_country_address": { "type": "string" },
        "japan_contact": {
          "type": "object",
          "properties": {
            "postal_code": { "type": "string" },
            "address": { "type": "string" },
            "phone": { "type": "string" },
            "mobile": { "type": "string" },
            "email": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "passport": {
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "expiry_date": { "type": "string" }
      },
      "additionalProperties": true
    },
    "residence_card": {
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "status": { "type": "string" },
        "expiry_date": { "type": "string" }
      },
      "additionalProperties": true
    },
    "immigration_history": {
      "type": "object",
      "properties": {
        "has_entries": { "type": "boolean" },
        "entries_count": { "type": ["integer", "string"] },
        "latest_entry": {
          "type": "object",
          "properties": {
            "start_date": { "type": "string" },
            "end_date": { "type": "string" }
          },
          "additionalProperties": true
        },
        "prior_coe_applications": {
          "type": "object",
          "properties": {
            "has_history": { "type": "boolean" },
            "count": { "type": ["integer", "string"] },
            "denial_count": { "type": ["integer", "string"] }
          },
          "additionalProperties": true
        },
        "criminal_record": { "type": "boolean" },
        "deportation_or_departure_order": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "family": {
      "type": "object",
      "properties": {
        "has_accompanying_members": { "type": "boolean" },
        "has_japan_relatives_or_cohabitants": { "type": "boolean" },
        "japan_relatives_or_cohabitants": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "education": { "type": "array", "items": { "type": "object" } },
    "transcript_subjects": { "type": "array", "items": { "type": "object" } },
    "employment_history": { "type": "array", "items": { "type": "object" } },
    "qualifications": { "type": "array", "items": { "type": "object" } },
    "employer": { "type": "object", "additionalProperties": true },
    "proxy": { "type": "object", "additionalProperties": true },
    "intermediary": { "type": "object", "additionalProperties": true },
    "receiving_method": { "type": "object", "additionalProperties": true },
    "supporting_documents": { "type": "array", "items": { "type": "object" } },
    "assessments": { "type": "array", "items": { "type": "object" } },
    "field_metadata": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}
